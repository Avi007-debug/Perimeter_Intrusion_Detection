# SentinelMesh-AI local configuration

# Flask / MQTT
FLASK_ENV=development
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
MQTT_BROKER=laptop_ip
MQTT_PORT=1883
HISTORY_MAXLEN=100

# Supabase project: SentinelMesh-AI
# Project Settings -> API -> Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Server-side key only. Use the service_role key in backend/.env or .env.
# Never expose this value in frontend/index.html.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_INCIDENTS_TABLE=incidents

# Telegram Alert Configuration
# Get token from BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Send a message to your bot and get chat ID from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Google Gemini AI Settings
# Required for generating natural-language incident reports (Phase 7)
GEMINI_API_KEY=your_gemini_api_key_here
